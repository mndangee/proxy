# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# electron-vite build
/out
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env.dev
.env.local
.env.prod
.env.stg

# typescript
*.tsbuildinfo

# electron-vite / tooling이 만든 일회성 설정 복사본
electron.vite.config.*.mjs

# oag (generated types)
/src/types/oag/*
!/src/types/oag/models/
!/src/types/oag/runtime.ts
